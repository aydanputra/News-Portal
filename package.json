{
  "name": "news-portal",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "dev:turbo": "cross-env NEXT_TELEMETRY_DISABLED=1 next dev --turbo",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "build": "next build",
    "vercel-build": "prisma migrate deploy && next build",
    "build:prod": "cross-env NEXT_DIST_DIR=.next-prod next build",
    "build:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});require('fs').rmSync('.next-prod',{recursive:true,force:true})\" && next build",
    "build:prod:clean": "node -e \"require('fs').rmSync('.next-prod',{recursive:true,force:true})\" && cross-env NEXT_DIST_DIR=.next-prod next build",
    "start": "next start",
    "start:prod": "cross-env NEXT_DIST_DIR=.next-prod next start",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});require('fs').rmSync('.next-prod',{recursive:true,force:true})\"",
    "rebuild": "npm run clean && npm run build",
    "lint": "next lint",
    "migrate:homepage-config": "npx ts-node scripts/normalize-homepage-block-config-keys.ts --theme=pranala --location=home",
    "migrate:homepage-config:apply": "npx ts-node scripts/normalize-homepage-block-config-keys.ts --apply --theme=pranala --location=home",
    "rollback:homepage-config": "npx ts-node scripts/restore-homepage-block-config-backup.ts",
    "seed:post-builder:pranala": "npx ts-node -O '{\"module\":\"CommonJS\"}' scripts/seed-pranala-post-builder.ts",
    "seed:post-builder:pranala:apply": "npx ts-node -O '{\"module\":\"CommonJS\"}' scripts/seed-pranala-post-builder.ts --apply",
    "seed:post-builder:pranala:reset": "npx ts-node -O '{\"module\":\"CommonJS\"}' scripts/seed-pranala-post-builder.ts --reset --apply"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.989.0",
    "@aws-sdk/s3-request-presigner": "^3.989.0",
    "@ckeditor/ckeditor5-react": "^11.0.1",
    "@prisma/client": "^6.3.0",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "ckeditor5": "^47.5.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html-react-parser": "^5.2.17",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.474.0",
    "next": "^15.5.18",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.0.0",
    "react-pageflip": "^2.0.3",
    "react-pdf": "^10.4.1",
    "react-quill-new": "^3.7.0",
    "sanitize-html": "^2.17.1",
    "sharp": "^0.34.5",
    "swiper": "^12.1.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "xml2js": "^0.6.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.0",
    "@types/xml2js": "^0.4.14",
    "autoprefixer": "^10.4.24",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "^15.5.18",
    "postcss": "8.5.15",
    "prisma": "^6.3.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15",
    "quill": "2.0.2"
  }
}
